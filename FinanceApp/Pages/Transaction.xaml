<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceApp.Pages.Transaction"
             xmlns:models="clr-namespace:FinanceApp.Models"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource MainColor}"
             Title="Transaction">
    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20,10">
            <Image Grid.Column="0" Source="back_arrow.png" HeightRequest="25">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Back"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1" Text="Transaction" FontSize="22" FontAttributes="Bold" 
                   TextColor="{StaticResource Black}" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border Grid.Column="2" BackgroundColor="{StaticResource White}" HeightRequest="45" WidthRequest="45" StrokeShape="RoundRectangle 22">
                <Image Source="bell.png" HeightRequest="20" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="notification"/>
                    </Image.GestureRecognizers>
                </Image>
            </Border>
        </Grid>

        <Border Grid.Row="1" Margin="20,10" Padding="15" BackgroundColor="{StaticResource White}" 
                StrokeShape="RoundRectangle 25" StrokeThickness="0">
            <VerticalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Total Balance" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Black}" HorizontalOptions="Center"/>
                <Label Text="$7,783.00" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource Black}" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" Padding="20,10,20,20">
            <Border Grid.Column="0" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 25" Padding="15">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="0">
                    <Image Source="up.png" HeightRequest="40"/>
                    <Label Text="Income" FontSize="14" TextColor="{StaticResource Black}" HorizontalOptions="Center"/>
                    <Label Text="$4,120.00" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Black}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnIncomeClick"/>
                </Border.GestureRecognizers>
            </Border>

            <Border Grid.Column="1" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 25" Padding="25">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="3">
                    <Image Source="down_arrows.png" HeightRequest="25"/>
                    <Label Text="Expense" FontSize="14" TextColor="{StaticResource Black}" HorizontalOptions="Center"/>
                    <Label Text="$1,187.40" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Blue}" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnIncomeClick"/>
                </Border.GestureRecognizers>
            </Border>
        </Grid>

        <Frame Grid.Row="3" CornerRadius="60" BackgroundColor="{StaticResource Light}" Margin="0,0,0,-70" Padding="0" HasShadow="False">
            <Grid RowDefinitions="Auto, *">

                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="30,30,30,10">
                    <Label Text="Activity" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Black}"/>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource MainColor}" HeightRequest="35" WidthRequest="35" StrokeShape="RoundRectangle 10">
                        <Image Source="calendar.png" HeightRequest="20"/>
                    </Border>
                </Grid>

                <CollectionView Grid.Row="1" x:Name="TransactionList" IsGrouped="True" Margin="20,0,20,70">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" 
                                   TextColor="{StaticResource Black}" Margin="0,15,0,10"/>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:DashboardTransaction">
                            <Grid ColumnDefinitions="60, *, 1, 80, 1, 90" ColumnSpacing="5" Padding="0,12">
                                <Frame Grid.Column="0" BackgroundColor="{StaticResource MainColor}" 
                                       CornerRadius="20" WidthRequest="55" HeightRequest="55" Padding="11">
                                    <Image Source="{Binding Icon}"/>
                                </Frame>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="5,0">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" TextColor="{StaticResource Black}" MaxLines="1"/>
                                    <Label Text="{Binding Date}" FontSize="11" TextColor="{StaticResource Blue}"/>
                                </VerticalStackLayout>

                                <BoxView Grid.Column="2" WidthRequest="1" Color="{StaticResource Gray200}" VerticalOptions="Fill" Margin="0,10"/>

                                <Label Grid.Column="3" Text="{Binding TypeName}" VerticalOptions="Center" 
                                       HorizontalOptions="Center" FontAttributes="Bold" TextColor="{StaticResource IconColor}" FontSize="12"/>

                                <BoxView Grid.Column="4" WidthRequest="1" Color="{StaticResource Gray200}" VerticalOptions="Fill" Margin="0,10"/>

                                <Label Grid.Column="5" Text="{Binding Amount}" FontAttributes="Bold" 
                                       VerticalOptions="Center" TextColor="{Binding AmountColor}" HorizontalTextAlignment="End" Margin="0,0,5,0"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>