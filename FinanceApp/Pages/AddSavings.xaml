<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceApp.Pages.AddSavings"
             Shell.NavBarIsVisible="False" 
             BackgroundColor="{StaticResource MainColor}">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20,10">
            <Image Source="back_arrow.png" HeightRequest="25">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Back"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1" Text="Add Savings" FontSize="22" FontAttributes="Bold" 
                   TextColor="{StaticResource Black}" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border Grid.Column="2" BackgroundColor="{StaticResource White}" HeightRequest="45" WidthRequest="45" StrokeShape="RoundRectangle 22">
                <Image Source="bell.png" HeightRequest="20" VerticalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="notification"/>
                    </Image.GestureRecognizers>
                </Image>
            </Border>
        </Grid>

        <Frame Grid.Row="1" CornerRadius="60" BackgroundColor="{StaticResource Light}" Margin="0,30,0,-70" Padding="0" HasShadow="False">
            <ScrollView Orientation="Vertical">
                <VerticalStackLayout Padding="25,40,25,100" Spacing="20">

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Date" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Black}"/>
                        <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource EntryBG}" HeightRequest="55" StrokeThickness="0">
                            <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                                <Label x:Name="SelectedDateLabel" Text="Select Date" VerticalOptions="Center" TextColor="{StaticResource Black}"/>
                                <Image Grid.Column="1" Source="calendar.png" HeightRequest="22" VerticalOptions="Center"/>
                                <DatePicker Grid.ColumnSpan="2" x:Name="MyDatePicker" Opacity="0" DateSelected="OnDateSelected"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Category" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Black}"/>
                        <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource EntryBG}" HeightRequest="55" StrokeThickness="0">
                            <Grid ColumnDefinitions="*, Auto" Padding="20,0">
                                <Picker x:Name="CategoryPicker" Title="Select the category" TextColor="{StaticResource Black}" VerticalOptions="Center"/>
                                <Image Grid.Column="1" Source="down_arrow.png" HeightRequest="12" VerticalOptions="Center" InputTransparent="True"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Amount" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Black}"/>
                        <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource EntryBG}" HeightRequest="55" StrokeThickness="0">
                            <Entry Placeholder="$ 0.00" PlaceholderColor="{StaticResource Gray400}" TextColor="{StaticResource Black}" Keyboard="Numeric" VerticalOptions="Center" Margin="15,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Savings Title" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource Black}"/>
                        <Border StrokeShape="RoundRectangle 15" BackgroundColor="{StaticResource EntryBG}" HeightRequest="55" StrokeThickness="0">
                            <Entry Placeholder="e.g. Dream Car" PlaceholderColor="{StaticResource Gray400}" TextColor="{StaticResource Black}" VerticalOptions="Center" Margin="15,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Enter Message" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource MainColor}"/>
                        <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource EntryBG}" HeightRequest="120" StrokeThickness="0">
                            <Editor Placeholder="Type here..." PlaceholderColor="{StaticResource Gray400}" TextColor="{StaticResource Black}" AutoSize="Disabled" Margin="10"/>
                        </Border>
                    </VerticalStackLayout>

                    <Button Text="Save" BackgroundColor="{StaticResource MainColor}" TextColor="{StaticResource Black}" 
                            FontAttributes="Bold" FontSize="18" CornerRadius="25" HeightRequest="60" 
                            Margin="0,10,0,0" Clicked="OnSaveClicked"/>

                </VerticalStackLayout>
            </ScrollView>
        </Frame>
    </Grid>
</ContentPage>