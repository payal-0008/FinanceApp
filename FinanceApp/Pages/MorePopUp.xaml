<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
             x:Class="FinanceApp.Pages.MorePopUp"
             BackgroundColor="#80000000">
    <Frame VerticalOptions="Center" 
           HorizontalOptions="Center" 
           Padding="25"
           CornerRadius="30" 
           BackgroundColor="White" 
           HasShadow="True"
           WidthRequest="350">

        <VerticalStackLayout Spacing="20"   HorizontalOptions="FillAndExpand">

            <Label Text="New Category" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Black}" 
                   HorizontalOptions="Center"/>

            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="{StaticResource EntryBG}"
                    HeightRequest="50"
                    Padding="15,0">

                <Entry Placeholder="Write..."
                       PlaceholderColor="{StaticResource MainColor}"
                       TextColor="{StaticResource Black}"
                       FontSize="16"
                       VerticalOptions="Center"/>
            </Border>
            <VerticalStackLayout Spacing="12" Margin="0,10,0,0">
                <Button Text="Save" 
                        BackgroundColor="{StaticResource MainColor}" 
                        TextColor="{StaticResource Black}" 
                        CornerRadius="20" 
                        HeightRequest="55" 
                        FontAttributes="Bold"
                        Clicked="OnSaveClicked"/>

                <Button Text="Cancel" 
                        BackgroundColor="{StaticResource EntryBG}" 
                        TextColor="{StaticResource Black}" 
                        CornerRadius="20" 
                        HeightRequest="55" 
                        FontAttributes="Bold"
                        Clicked="OnCancelClicked"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Frame>
</mopups:PopupPage>