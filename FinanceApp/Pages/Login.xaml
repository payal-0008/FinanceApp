        <Grid  Grid.Row="0" Margin="70">
        <Label Text="Welcome" TextColor="{StaticResource Black}" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" FontSize="25" FontAttributes="Bold"/>
        </Grid>
        <Frame Grid.Row="1"
               CornerRadius="55">
