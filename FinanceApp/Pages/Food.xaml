<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceApp.Pages.Food"
             xmlns:models="clr-namespace:FinanceApp.Models"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource MainColor}"
             Title="Food">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" RowDefinitions="Auto, Auto, Auto, Auto" Padding="25">
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="0,10">
                <Image Source="back_arrow.png" HeightRequest="25">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Tapped="Back"/>
                    </Image.GestureRecognizers>
                </Image>
                <Label Grid.Column="1" Text="Food" FontSize="22" FontAttributes="Bold" 
                       TextColor="{StaticResource Black}" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Border Grid.Column="2" BackgroundColor="{StaticResource White}" HeightRequest="45" WidthRequest="45" StrokeShape="RoundRectangle 22">
                    <Image Source="bell.png" HeightRequest="20" VerticalOptions="Center">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="notification"/>
                        </Image.GestureRecognizers>
                    </Image>
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*, 1, *" Margin="0,18,0,0">
                <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <Image Source="up.png" HeightRequest="15" WidthRequest="15"/>
                        <Label Text="Total Balance" FontSize="15" TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Label Text="$7,783.00" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource White}"/>
                </VerticalStackLayout>
                <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="{StaticResource White}" Margin="0,10"/>
                <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                    <HorizontalStackLayout Spacing="5">
                        <Image Source="down_arrows.png" HeightRequest="10" WidthRequest="10"/>
                        <Label Text="Total Expense" FontSize="15" TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <Label Text="-$1,187.40" FontSize="26" FontAttributes="Bold" TextColor="{StaticResource Blue}"/>
                </VerticalStackLayout>
            </Grid>

            <Grid Grid.Row="2" Margin="0,25,0,10">
                <Border HeightRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="{StaticResource White}">
                    <Label Text="$20,000.00" TextColor="{StaticResource Black}" FontSize="14" FontAttributes="Bold" 
                           HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,20,0"/>
                </Border>
                <Border HorizontalOptions="Start" WidthRequest="110" HeightRequest="40" 
                        StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="{StaticResource Black}">
                    <Label Text="30%" TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                </Border>
            </Grid>

            <HorizontalStackLayout Grid.Row="3" Spacing="10" HorizontalOptions="Center">
                <Image Source="check_icon.png" HeightRequest="18" WidthRequest="18"/>
                <Label Text="30% Of Your Expenses, Looks Good." TextColor="{StaticResource Black}" FontSize="15"/>
            </HorizontalStackLayout>
        </Grid>

        <Frame Grid.Row="1" CornerRadius="60" BackgroundColor="{StaticResource Light}" Margin="0,0,0,-70" Padding="0" HasShadow="False">
            <Grid RowDefinitions="*, Auto">

                <CollectionView Grid.Row="0" x:Name="FoodTransactionsList" IsGrouped="True" Margin="25,30,25,0">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto" Padding="0,10">
                                <Label Text="{Binding GroupTitle}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource IconColor}" VerticalOptions="Center"/>
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 10" BackgroundColor="{StaticResource MainColor}" HeightRequest="35" WidthRequest="35">
                                    <Image Source="calendar.png" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TransactionModel">
                            <Grid ColumnDefinitions="60, *, Auto" ColumnSpacing="15" Padding="0,12">
                                <Border StrokeShape="RoundRectangle 20" BackgroundColor="{StaticResource MainColor}" HeightRequest="60" WidthRequest="60">
                                    <Image Source="{Binding Icon}" HeightRequest="35" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource IconColor}"/>
                                    <Label Text="{Binding Date}" FontSize="12" TextColor="{StaticResource Blue}"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding Amount}" VerticalOptions="Center" FontAttributes="Bold" TextColor="{Binding AmountColor}"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Grid.Row="1" Text="Add Expenses" BackgroundColor="{StaticResource MainColor}" 
                        TextColor="{StaticResource Black}" CornerRadius="25" HeightRequest="55" FontAttributes="Bold" 
                        Margin="40,10,40,90" Clicked="OnAddExpensesClick"/>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>