<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceApp.Pages.Notification"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource MainColor}"
             Title="Notification">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20,10">
            <Image Grid.Column="0" Source="back_arrow.png" HeightRequest="25" BackgroundColor="{StaticResource transparent}">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Back"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Grid.Column="1" Text="Notification" FontSize="22" FontAttributes="Bold" 
               TextColor="{StaticResource White}" HorizontalOptions="Center" VerticalOptions="Center"/>
            <Border Grid.Column="2" BackgroundColor="{StaticResource White}" HeightRequest="45" WidthRequest="45" StrokeShape="RoundRectangle 22">
                <Image Source="bell.png" HeightRequest="20" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 40,40,0,0" Padding="15" Margin="0,0,0,-20">
            <ScrollView>
                <VerticalStackLayout Spacing="15">

                    <Label Text="Today" TextColor="{StaticResource Black}" FontSize="14" Margin="10,0,0,0" FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="55, *" RowDefinitions="*, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Image Source="bell.png" HeightRequest="25"/>
                        </Border>
                        <Label Grid.Column="1" Text="Reminder!" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="Set up your automatic savings to meet your savings goal..." TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,30,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource MainColor}" Margin="0,5"/>
                    <Grid ColumnDefinitions="55, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Image Source="star.png" HeightRequest="25"/>
                        </Border>
                        <Label Grid.Column="1" Text="New Update" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="Set up your automatic savings to meet your savings goal..." TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,30,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource MainColor}" Margin="0,5"/>

                    <Label Text="Yesterday" TextColor="{StaticResource Black }" FontSize="14" Margin="20,10" FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="55, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Label Text="$" FontSize="35" TextColor="{StaticResource Black}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="Transactions" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="A new transaction has been registered" TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Grid.Row="1" Margin="0,20,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Groceries | Pantry | " TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                                    <Span Text="-$100,00" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,30,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource MainColor}" Margin="0,5"/>
                    <Grid ColumnDefinitions="55, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Image Source="bell.png" HeightRequest="25"/>
                        </Border>
                        <Label Grid.Column="1" Text="Reminder!" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="Set up your automatic savings to meet your savings goal..." TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,30,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource MainColor}" Margin="0,5"/>

                    <Label Text="This Weekend" TextColor="{StaticResource Black}" FontSize="14" Margin="20,0,0,0" FontAttributes="Bold"/>

                    <Grid ColumnDefinitions="55, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Image Source="down_arrows.png" HeightRequest="25"/>
                        </Border>
                        <Label Grid.Column="1" Text="Expense Record" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="We recommend that you be more attentive to your finances." TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,20,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource MainColor}" Margin="0,5"/>
                    <Grid ColumnDefinitions="55, *" RowDefinitions="Auto, Auto" ColumnSpacing="15">
                        <Border Grid.RowSpan="2" HeightRequest="50" WidthRequest="50" BackgroundColor="{StaticResource MainColor}" StrokeShape="RoundRectangle 15">
                            <Label Text="$" FontSize="35" TextColor="{StaticResource Black}" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="Transactions" FontAttributes="Bold" FontSize="18" TextColor="{StaticResource Black}"/>
                        <Label Grid.Column="1" Grid.Row="1" Text="A new transaction has been registered" TextColor="{StaticResource Black}" FontAttributes="Bold"/>
                        <Label Grid.Column="1" Grid.Row="1" Margin="0,20,0,0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Food | Dinner | " TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                                    <Span Text="-$70,40" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Label Grid.Row="1" Grid.Column="1" Text="17:00 - April 24" HorizontalOptions="End" VerticalOptions="End" Margin="0,20,0,0" TextColor="{StaticResource Blue}" FontAttributes="Bold"/>
                    </Grid>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>