<?xml version="1.0" encoding="utf-8" ?>
<mopups:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mopups="clr-namespace:Mopups.Pages;assembly=Mopups"
             x:Class="FinanceApp.Pages.LogOut"
             BackgroundColor="#80000000">
    <Frame VerticalOptions="Center" 
           HorizontalOptions="Center" 
           Margin="30"
           Padding="25"
           CornerRadius="30" 
           BackgroundColor="White" 
           HasShadow="True"
           WidthRequest="350">

        <VerticalStackLayout Spacing="20" HorizontalOptions="Center">

            <Label Text="End Session" 
                   FontSize="22" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Black}" 
                   HorizontalOptions="Center"/>

            <Label Text="Are You Sure You Want To Log Out?" 
                   FontSize="16" 
                   TextColor="{StaticResource Black}" 
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"/>
            
            <VerticalStackLayout Spacing="12" Margin="0,10,0,0">
                <Button Text="Yes, End Session" 
                        BackgroundColor="{StaticResource MainColor}" 
                        TextColor="{StaticResource Black}" 
                        CornerRadius="30" 
                        HeightRequest="55" 
                        FontAttributes="Bold"
                        Clicked="OnConfirmDeleteClicked"/>

                <Button Text="Cancel" 
                        BackgroundColor="{StaticResource EntryBG}" 
                        TextColor="{StaticResource Black}" 
                        CornerRadius="30" 
                        HeightRequest="55" 
                        FontAttributes="Bold"
                        Clicked="OnCancelClicked"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Frame>
</mopups:PopupPage>